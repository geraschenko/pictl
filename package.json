{
  "name": "pictl",
  "version": "0.1.0",
  "description": "Spawn, observe, control, and attach to a fleet of pi coding-agent instances",
  "type": "module",
  "bin": {
    "pictl": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --test \"src/**/*.test.ts\"",
    "fmt": "treefmt",
    "presubmit": "npm run check && npm run lint && treefmt --fail-on-change && npm test"
  },
  "dependencies": {
    "@geraschenko/pi-coding-agent": "0.79.6-fork.1",
    "@stricli/core": "1.2.7",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.0"
  }
}
